{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "automatizei",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "../.vscode/*",
      "../json/jwrangler.jsonc"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}